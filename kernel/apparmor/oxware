# AnkaVM Hypervisor AppArmor Profile
# Install: sudo cp kernel/apparmor/ankavm /etc/apparmor.d/opt.ankavm.backend.app
#          sudo apparmor_parser -r /etc/apparmor.d/opt.ankavm.backend.app
#          sudo aa-enforce /etc/apparmor.d/opt.ankavm.backend.app
#
# Test (complain mode first): sudo aa-complain /etc/apparmor.d/opt.ankavm.backend.app
# Check logs: sudo journalctl -f | grep apparmor

#include <tunables/global>

profile ankavm /opt/ankavm/venv/bin/python3 flags=(attach_disconnected,mediate_deleted) {

  #include <abstractions/base>
  #include <abstractions/python>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>

  # â”€â”€ Capabilities â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  # net_admin: libvirt network management, nftables, iptables
  # sys_ptrace: virsh console / qemu guest-agent
  # dac_override: read libvirt socket owned by root/libvirt
  # setuid/setgid: NOT granted â€” ankavm runs as root already
  capability net_admin,
  capability net_raw,
  capability sys_ptrace,
  capability dac_override,
  capability dac_read_search,
  capability sys_admin,         # libvirt XML inject, mount namespaces
  capability kill,              # send signals to managed qemu processes
  capability fowner,
  capability fsetid,

  # â”€â”€ Network â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  network inet  stream,
  network inet6 stream,
  network unix  stream,
  network unix  dgram,
  network netlink raw,          # nftables netlink
  network packet raw,           # nftables packet processing

  # â”€â”€ AnkaVM application files â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /opt/ankavm/**                r,
  /opt/ankavm/venv/bin/**       ix,
  /opt/ankavm/venv/lib/**       r,
  /opt/ankavm/ankavm/**         r,
  /opt/ankavm/ankavm/backend/app.py r,

  # â”€â”€ Config & data â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /etc/ankavm/                  r,
  /etc/ankavm/**                rw,
  /var/lib/ankavm/              r,
  /var/lib/ankavm/**            rw,
  /var/log/ankavm/              r,
  /var/log/ankavm/**            rw,
  /tmp/ankavm*                  rw,
  /tmp/                         r,

  # â”€â”€ libvirt / KVM â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /run/libvirt/                 r,
  /run/libvirt/**               rw,
  /var/run/libvirt/             r,
  /var/run/libvirt/**           rw,
  /var/lib/libvirt/             r,
  /var/lib/libvirt/**           rw,
  /var/lib/libvirt/images/      rw,
  /var/lib/libvirt/images/**    rw,
  /var/lib/libvirt/boot/        r,
  /var/lib/libvirt/boot/**      r,
  /dev/kvm                      rw,
  /dev/vhost-net                rw,
  /dev/net/tun                  rw,
  /dev/tap*                     rw,
  /sys/devices/system/cpu/**    r,
  /sys/class/net/**             r,
  /sys/bus/pci/**               r,
  /proc/sys/net/**              r,

  # â”€â”€ QEMU / swtpm binaries (execute, not confined by this profile) â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /usr/bin/qemu-system-x86_64   ix,
  /usr/bin/qemu-system-aarch64  ix,
  /usr/bin/qemu-img             ix,
  /usr/bin/qemu-nbd             ix,
  /usr/sbin/swtpm               ix,
  /usr/bin/virsh                ix,
  /usr/sbin/libvirtd            ix,
  /usr/bin/nft                  ix,
  /usr/sbin/iptables            ix,
  /usr/sbin/ip6tables           ix,
  /usr/sbin/ip                  ix,
  /usr/bin/rsync                ix,
  /usr/bin/ssh                  ix,
  /usr/bin/openssl              ix,
  /usr/bin/python3*             ix,
  /usr/bin/python3              ix,

  # â”€â”€ System reads â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /proc/*/net/**                r,
  /proc/meminfo                 r,
  /proc/cpuinfo                 r,
  /proc/loadavg                 r,
  /proc/uptime                  r,
  /proc/stat                    r,
  /proc/*/stat                  r,
  /proc/*/status                r,
  /proc/*/cmdline               r,
  /proc/*/exe                   r,
  /proc/*/maps                  r,
  /proc/*/fd/                   r,
  /proc/*/cgroup                r,
  /sys/kernel/mm/hugepages/**   rw,
  /sys/devices/system/node/**   r,
  /sys/block/**                 r,
  /sys/class/block/**           r,

  # â”€â”€ SSL certs â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /etc/ssl/certs/**             r,
  /etc/ssl/private/             r,
  /etc/ssl/private/**           r,
  /etc/ca-certificates/**       r,
  /usr/share/ca-certificates/** r,

  # â”€â”€ Python stdlib & site-packages â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /usr/lib/python3*/            r,
  /usr/lib/python3/**           r,
  /usr/local/lib/python3*/      r,
  /usr/local/lib/python3/**     r,

  # â”€â”€ noVNC / static files â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /opt/ankavm/novnc/            r,
  /opt/ankavm/novnc/**          r,

  # â”€â”€ ISO / disk images â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  /var/lib/ankavm/isos/         rw,
  /var/lib/ankavm/isos/**       rw,
  /var/lib/ankavm/disks/        rw,
  /var/lib/ankavm/disks/**      rw,
  /var/lib/ankavm/backups/      rw,
  /var/lib/ankavm/backups/**    rw,
  /var/lib/ankavm/templates/    rw,
  /var/lib/ankavm/templates/**  rw,
  /var/lib/swtpm/               rw,
  /var/lib/swtpm/**             rw,

  # â”€â”€ DENY sensitive paths (explicit deny) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  deny /etc/shadow              rw,
  deny /etc/gshadow             rw,
  deny /root/.ssh/              rw,
  deny /home/**/.ssh/           rw,
  deny /proc/sysrq-trigger      w,
  deny /proc/*/mem              w,
  deny /sys/firmware/           w,
  deny /sys/kernel/security/    w,

  # â”€â”€ Unix sockets â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  unix (send, receive, connect) peer=(label=unconfined),
  /run/user/*/                  rw,
  /run/user/**                  rw,
}
