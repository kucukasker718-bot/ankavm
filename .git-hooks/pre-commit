#!/usr/bin/env bash
# OXware pre-commit hook — auto-inject i18n updates when index.html changes.
#
# Install:  ln -sf ../../.git-hooks/pre-commit .git/hooks/pre-commit
set -e

changed=$(git diff --cached --name-only)

if echo "$changed" | grep -q "oxware/frontend/templates/index.html"; then
  echo "→ index.html changed; refreshing PAGE_STRINGS via i18n pipeline..."
  python3 scripts/i18n_pipeline.py || {
    echo "i18n pipeline failed (untranslated TR strings) — see tmp_i18n/missing_*.txt"
    echo "Run 'make i18n' locally and commit the regenerated index.html."
    exit 1
  }
  git add oxware/frontend/templates/index.html
fi
